{
  "name": "rechris-atlas",
  "private": true,
  "description": "RECHRIS ATLAS personal design, photo, and daily systems site",
  "scripts": {
    "dev": "vite",
    "photos:previews": "node scripts/generate-photo-previews.js",
    "site:images": "node scripts/generate-site-images.js",
    "photos:enrich": "node scripts/enrich-photo-records.js",
    "photos:sync": "npm run photos:previews && node scripts/sync-photo-records.js && npm run photos:enrich",
    "smoke": "node scripts/smoke-check.js",
    "build": "node check-photo-assets.js && npm run smoke && vite build && node scripts/check-asset-budgets.js",
    "preview": "vite preview --host 0.0.0.0",
    "lint": "eslint src --ext .js,.jsx",
    "lint:fix": "eslint src --ext .js,.jsx --fix",
    "format": "prettier --write \"src/**/*.{js,jsx,css}\"",
    "format:check": "prettier --check \"src/**/*.{js,jsx,css}\""
  },
  "dependencies": {
    "@panzoom/panzoom": "^4.6.2",
    "@vercel/analytics": "^2.0.1",
    "@vercel/kv": "^3.0.0",
    "@vercel/speed-insights": "^2.0.0",
    "exifr": "^7.1.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.1",
    "esbuild": "^0.28.0",
    "eslint": "^8.57.0",
    "eslint-plugin-react": "^7.34.1",
    "eslint-plugin-react-hooks": "^4.6.0",
    "prettier": "^3.2.5",
    "vite": "^8.0.10"
  }
}
